{
  "Proxmox": {
    "BaseUrl": "https://localhost:8006/",
    "ApiTokenId": "",
    "ApiTokenSecret": "",
    "Username": "",
    "Password": "",
    "TotpCode": "",
    "IgnoreCertificateErrors": false,
    "CaCertificatePath": null,
    "RequestTimeoutSeconds": 60,
    "UserAgent": "ProxmoxMCPSharp",
    "DefaultNode": "",
    "ReadOnly": true,
    "AllowedNodes": [],
    "BlockedNodes": [],
    "AllowedVmIds": [],
    "BlockedVmIds": [],
    "EnableNodes": true,
    "EnableQemu": true,
    "EnableLxc": true,
    "EnableStorage": true,
    "EnableSnapshots": true,
    "EnableBackups": true,
    "EnableCluster": true,
    "EnableNetwork": true,
    "EnableTasks": true,
    "EnableQemuAgent": true,
    "EnableApt": true,
    "EnableFirewall": true,
    "EnableRestore": true,
    "AllowDestroy": false,
    "AllowManualBackup": true,
    "AllowSnapshotRollback": false,
    "AllowGuestExec": false,
    "AllowGuestFileWrite": false,
    "AllowGuestPasswordChange": false,
    "DefaultStorage": "local-lvm",
    "DefaultBridge": "vmbr0",
    "DefaultOsType": "l26"
  },
  "Server": {
    "Host": "localhost",
    "Port": 5705,
    "Path": "/mcp",
    "WindowsServiceName": "ProxmoxMCPSharp"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/proxmoxmcp-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 52428800,
          "rollOnFileSizeLimit": true,
          "shared": true,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ]
  }
}
